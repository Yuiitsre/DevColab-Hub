# ══════════════════════════════════════════════
# DevCollab Hub — Environment Variables
# Run: npm run generate-keys  to generate secrets
# ══════════════════════════════════════════════

# Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app

# Security Keys (generate with: npm run generate-keys)
JWT_SECRET=CHANGE_THIS_generate_with_npm_run_generate_keys
ENCRYPTION_KEY=CHANGE_THIS_must_be_64_hex_chars_exactly
WEBHOOK_SECRET=CHANGE_THIS_github_webhook_signature_secret

# GitHub OAuth App
# Create at: github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=https://devcolab-backend.onrender.com/api/auth/github/callback

# GitHub Personal Access Token (server-side API calls)
GITHUB_TOKEN=your_github_pat_here

# Gemini AI
GEMINI_KEY=your_gemini_api_key_here

# Supabase Database
# Create at: app.supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
